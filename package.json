{
  "name": "antigravity",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous AI business operating system for the Google Gemini XPRIZE Hackathon.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @antigravity/web",
    "dev:web": "npm run dev --workspace @antigravity/web",
    "dev:api": "python3 -m uvicorn antigravity_api.main:create_app --factory --app-dir services/api/src --host 127.0.0.1 --port 8000 --reload",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check:api": "python3 -m compileall services/api/src services/api/tests && PYTHONPATH=services/api/src python3 -m pytest services/api/tests"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.16.0",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.6",
    "eslint": "^9.30.1",
    "eslint-config-next": "^16.2.10",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "overrides": {
    "postcss": "^8.5.16"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
