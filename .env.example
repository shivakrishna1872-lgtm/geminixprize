# AntiGravity — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ---------------------------------------------------------------------------
# Google Cloud Platform
# ---------------------------------------------------------------------------
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ---------------------------------------------------------------------------
# Gemini / Vertex AI
# ---------------------------------------------------------------------------
GEMINI_MODEL=gemini-2.0-flash-001

# ---------------------------------------------------------------------------
# Google Pub/Sub
# ---------------------------------------------------------------------------
PUBSUB_TOPIC=agent-events
PUBSUB_SUBSCRIPTION=agent-events-sub

# ---------------------------------------------------------------------------
# Firestore
# ---------------------------------------------------------------------------
FIRESTORE_DATABASE=(default)

# ---------------------------------------------------------------------------
# Firebase Authentication
# ---------------------------------------------------------------------------
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-gcp-project-id

# ---------------------------------------------------------------------------
# Printify
# ---------------------------------------------------------------------------
PRINTIFY_API_KEY=your-printify-api-key
PRINTIFY_SHOP_ID=your-printify-shop-id

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ---------------------------------------------------------------------------
# Duda MCP
# ---------------------------------------------------------------------------
DUDA_API_KEY=your-duda-api-key
DUDA_API_SECRET=your-duda-api-secret
DUDA_SITE_TEMPLATE_ID=your-template-id

# ---------------------------------------------------------------------------
# Commerce Layer
# ---------------------------------------------------------------------------
COMMERCE_LAYER_CLIENT_ID=your-cl-client-id
COMMERCE_LAYER_CLIENT_SECRET=your-cl-client-secret
COMMERCE_LAYER_ORGANIZATION=your-organization-slug

# ---------------------------------------------------------------------------
# GitHub MCP
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-github-token
GITHUB_ORG=your-github-org

# ---------------------------------------------------------------------------
# Next.js Frontend (prefix with NEXT_PUBLIC_ for client-side access)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-gcp-project-id

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# Set to 'true' to use mock integrations (no real API calls)
USE_MOCK_INTEGRATIONS=true
MOCK_AGENT_DELAY_MS=800
